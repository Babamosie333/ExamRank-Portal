PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/mcq_test_platform
JWT_SECRET=use_any_long_random_string_here

# Admin credentials (used on first login to seed the admin account)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Gmail OAuth2 (for student OTP emails)
GMAIL_USER=your@gmail.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# CORS: comma-separated list of allowed frontend origins
# Leave empty in local development (allows all origins)
# Example for production: https://yoursite.com,https://admin.yoursite.com
ALLOWED_ORIGINS=
